  "version": "0.2.0",
  "configurations": [
    {
      "name": "flutter_core (Local Debug)",
      "request": "launch",
      "type": "dart",
      "args": ["--dart-define-from-file", ".env"]
    },
    {
      "name": "flutter_core (Dev Debug)",
      "request": "launch",
      "type": "dart",
      "args": ["--dart-define-from-file", ".env.dev"]
    },
    {
      "name": "flutter_core (Staging Debug)",
      "request": "launch",
      "type": "dart",
      "args": ["--dart-define-from-file", ".env.staging"]
    },
    {
      "name": "flutter_core (Production Debug)",
      "request": "launch",
      "type": "dart",
      "args": ["--dart-define-from-file", ".env.production"]
    },
    {
      "name": "Flutter test",
      "request": "launch",
      "type": "dart",
      "program": "test",
      "args": ["--coverage"]
    }
  ]
}
